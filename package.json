    "@tanstack/react-query": "^5.59.20",
    "burnt": "^0.12.2",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.36.4",
    "expo": "~52.0.11",
    "expo-constants": "~17.0.3",
    "expo-font": "~13.0.1",
