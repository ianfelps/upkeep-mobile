{
  "expo": {
    "name": "Upkeep",
    "slug": "upkeep-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "upkeep",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FAFAF9",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.upkeep.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAF9"
      },
      "package": "com.upkeep.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
